<!DOCTYPE html>
<head>
 
    <style>
        * {
  box-sizing: border-box;
}


/* Header/Blog Title */
.header {
  
  font-size: 40px;
  text-align: center;
  background: white;
}

/* Create two unequal columns that floats next to each other */
/* Left column */
.letcolumn {
  float: left;
  display: flex;
  flex-wrap: wrap;
}

/* Right column */
.rghtcolumn {
  float: right;
  
}
.eftcolumn > *{
  flex: 1 1 160px;
}

/* Fake image */
.fakeimg {
  background-color: #aaa;
  width: 100%;
  padding: 20px;
}

/* Add a card effect for articles */
.card {
  background-color: white;
  padding: 20px;
  margin-top: 20px;
  position: absolute;
}

/* Clear floats after the columns */
.row:after {
  content: "";
  display: table;
  clear: both;
}

/* Footer */
.footer {
 position: relative;
  text-align: center;
  background: #ddd;;
}

/* Responsive layout - when the screen is less than 800px wide, make the two columns stack on top of each other instead of next to each other */
@media screen and (max-width: 800px) {
  .leftcolumn, .rightcolumn {
    width: 100%;
    padding: 0;
  }
}
    </style>
</head>

  
  <div class="rw">

    <div clas="leftcolumn">
     
      <%- include('blog card'); %>
       
  </div>
      </div>

    <div>
      <div class="card">
        <h2>About Me</h2>
        <div class="fakeimg" style="height:100px;">Image</div>
        <p>Some text about me in culpa qui officia deserunt mollit anim..</p>
      </div>
      <div class="card">
        <h3>Popular Post</h3>
        <div class="fakeimg">  
           <% Object.keys(blogs).forEach(() => { %>
        <%  const keys = Object.keys(blogs); %>
       <% for (let key of keys) { %>
          <h1><%= blogs[key].title %></h1>
          <p><%= blogs[key].snippet %></p>
          <p><%= blogs[key].body %></p>
      <% }})%></div><br>
        <div class="fakeimg">Image</div><br>
        <div class="fakeimg">Image</div>
      </div>
      <div class="card">
        <h3>Follow Me</h3>
        <p>Some text..</p>
      </div>
    </div>
   
  </div>
  
  
  </html>